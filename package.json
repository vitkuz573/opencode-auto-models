  "devDependencies": {
    "@opencode-ai/plugin": "file:/usr/local/lib/opencode/node_modules/@opencode-ai/plugin",
    "@opencode-ai/sdk": "file:/usr/local/lib/opencode/node_modules/@opencode-ai/sdk",
