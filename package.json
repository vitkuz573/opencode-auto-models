{
  "name": "opencode-auto-models",
  "version": "0.1.0",
  "description": "OpenCode plugin that auto-discovers models from OpenAI-compatible providers",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitkuz573/opencode-auto-models.git"
  },
